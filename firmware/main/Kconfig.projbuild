menu "Ai Watch"

    config AIW_WIFI_SSID
        string "WiFi SSID (e.g. phone hotspot name)"
        default "iPhone"
        help
            2.4 GHz Wi-Fi name to connect (e.g. iPhone personal hotspot).

    config AIW_WIFI_PASSWORD
        string "WiFi password"
        default "12345678"
        help
            Wi-Fi password.

    config AIW_MENUCONFIG_WIFI_FALLBACK
        bool "No NVS: try menuconfig WiFi before SoftAP (60s)"
        default n
        help
            If disabled (default): NVS 里没有保存过 wifi_ssid 时，不再尝试 menuconfig 里的 SSID，直接进入 AiWatch-xxxx 热点配网页（避免误连教程默认 iPhone 却无法访问公网）。
            If enabled: 先按 CONFIG_AIW_WIFI_* 连 STA 最多 60 秒，失败再开 SoftAP。

    config AIW_SERVER_BASE_URL
        string "Backend base URL (no trailing slash)"
        default "http://222.186.32.214:8765"
        help
            FastAPI 服务地址。配网网页可覆盖并写入 NVS（srv_url）。

    config AIW_PROV_AP_PASSWORD
        string "SoftAP password (provisioning mode)"
        default "12345678"
        help
            开发板开热点配网时，手机连 AiWatch-xxxx 使用的 WPA2 密码。

    config AIW_DEVICE_NAME
        string "Device display name"
        default "ai-watch-01"

endmenu
